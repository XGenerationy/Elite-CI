{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CI Gate Configuration",
  "type": "object",
  "properties": {
    "parallelism": { "type": "integer", "minimum": 0 },
    "default_timeout_sec": { "type": "integer", "minimum": 0 },
    "pre_commit_budget_sec": { "type": "integer", "minimum": 0 },
    "pre_push_budget_sec": { "type": "integer", "minimum": 0 },
    "fail_fast_on_blocker": { "type": "boolean" },
    "incremental": { "type": "boolean" },
    "cache_enabled": { "type": "boolean" },
    "verbose": { "type": "boolean" }
  }
}
